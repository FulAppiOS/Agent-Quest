# Port the Agent Quest server listens on (HTTP + WebSocket).
PORT=4444

# Origin allowed by CORS — must match the client dev server URL.
CLIENT_URL=http://localhost:4445

# Enable LAN access so other devices on the same Wi-Fi can view the village.
# When on, CORS reflects any origin and the server prints reachable LAN URLs
# at startup. Values: 1 / true / yes / on. Default: off (localhost only).
# AGENT_QUEST_LAN=1
