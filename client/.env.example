# Port the Vite dev server binds to.
CLIENT_PORT=4445

# Base URL of the Agent Quest server (HTTP). Leave unset for auto-detection
# based on the browser's current host (works for both localhost and LAN).
# VITE_SERVER_URL=http://localhost:4444

# WebSocket URL of the Agent Quest server. Same auto-detection when unset.
# VITE_WS_URL=ws://localhost:4444/ws

# Enable LAN access: bind the Vite dev server to 0.0.0.0 so other devices
# on the same Wi-Fi can load the UI. Pair with AGENT_QUEST_LAN=1 in the
# server's .env for CORS to accept LAN origins. Default: off (localhost only).
# AGENT_QUEST_LAN=1
